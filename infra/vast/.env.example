# Vast.ai SSH connection details — copy to .env and fill in.
# The Vast.ai UI shows the full command like:
#   ssh -p 12345 root@ssh5.vast.ai -L 8080:localhost:8080
# Take the host, port, and user from there.

VAST_SSH_HOST=ssh5.vast.ai
VAST_SSH_PORT=12345
VAST_SSH_USER=root

# Remote workspace on the instance (auto-created by provision.sh)
VAST_REMOTE_DIR=/workspace/ict-trading-bot

# Optional: torch wheel index for Blackwell (RTX 5090) — cu128 nightly.
# Leave empty to use the default PyPI torch resolved by `uv sync`.
# TORCH_INDEX_URL=https://download.pytorch.org/whl/nightly/cu128
